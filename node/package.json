{
  "name": "@stockseyes/node",
  "version": "1.0.0",
  "description": "Official Stockseyes SDK for Node.js — real-time Indian stock market (NSE/BSE) quotes, instrument search, and market data via RapidAPI.",
  "author": "Tushar Singhal",
  "license": "MIT",
  "keywords": [
    "stockseyes",
    "stocks",
    "stock-market",
    "nse",
    "bse",
    "rapidapi",
    "finance",
    "market-data",
    "india",
    "indian-stock-market",
    "quotes",
    "dashboard"
  ],
  "homepage": "https://github.com/stockseyes/stockseyes-package/tree/main/node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stockseyes/stockseyes-package.git",
    "directory": "node"
  },
  "bugs": {
    "url": "https://github.com/stockseyes/stockseyes-package/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.4",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "size-limit": "^11.1.4",
    "@size-limit/esbuild-why": "^11.1.4",
    "terser": "^5.31.1",
    "tsup": "^8.1.0",
    "tslib": "^2.6.3",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB"
    },
    {
      "path": "dist/index.mjs",
      "limit": "10 KB"
    }
  ]
}
